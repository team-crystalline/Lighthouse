<!DOCTYPE html>
<html lang="en" dir="ltr">

<head>
    <%- include ("../partials/header.ejs") %>

    <style>
        .radio-toolbar input[type="radio"] {
         display: none;
}

.radio-toolbar label {
  display: block;
  cursor: pointer;
  width: 6em;
  height: 6em;
  text-align:center;
}

.radio-toolbar input[type="radio"]:checked ~ * { 
    background:#9CD9D3 !important;
}
.pixelart{
    image-rendering: pixelated;
  image-rendering: -moz-crisp-edges;
  image-rendering: crisp-edges;
}

#blogpopup{
    width: 40vw;
    text-align: center;
}
form>span{
    display: block;
    margin-bottom:calc(1em);
}
table{
    width: 70%;
}
td{
    padding: calc(.5em);
    border-bottom: 1px solid rgba(0,0,0,.2)
}
    </style>
</head>

<body>
    <%- include ("../partials/nav.ejs") %>
    <% var journalArr= [
        {val: '1', c: "Red"}, 
        {val: '2', c: "Orange"}, 
        {val: '3', c: "Yellow"}, 
        {val: '4', c: "Green"}, 
        {val: '5', c: "Teal"}, 
        {val: '6', c: "Blue"}, 
        {val: '7', c: "Purple"}, 
        {val: '8', c: "Pink"}, 
        {val: '9', c: "White"}, 
        {val: '10', c: "Black"}, 
        {val: '11', c: "Rainbow"}, 
        {val: '12', c: "Ocean"}, 
        {val: '13', c: "Space"}, 
        {val: '14', c: "Winter"}, 
        {val: '15', c: "Autumn"}, 
        {val: '16', c: "Spring"}, 
        {val: '17', c: "Summer"}, 
        {val: '18', c: "Flowers"}, 
    ]
    var moods=[
    // Positive
    {name: "Joyous", positive: true, emoji: "😄"},
    {name: "Loved", positive: true, emoji: "🤗"},
    {name: "Satisfied", positive: true, emoji: "🙂"},
    {name: "Content", positive: true, emoji: "😌"},
    {name: "Interested", positive: true, emoji: "😮"},
    {name: "Amused", positive: true, emoji: "😆"},
    {name: "Happy", positive: true, emoji: "😀"},
    {name: "Serene", positive: true, emoji: "☺"},
    {name: "Awestruck", positive: true, emoji: "🤩"},
    {name: "Sleepy", positive: true, emoji: "😴"},
    // Negative
    {name: "Afraid", positive: false, emoji: "😨"},
    {name: "Frustrated", positive: false, emoji: "😖"},
    {name: "Overwhelmed", positive: false, emoji: "😖"},
    {name: "Dazed", positive: false, emoji: "😵"},
    {name: "Confused", positive: false, emoji: "😵"},
    {name: "Angry", positive: false, emoji: "😡"},
    {name: "Enraged", positive: false, emoji: "🤬"},
    {name: "Disgusted", positive: false, emoji: "🤢"},
    {name: "Sad", positive: false, emoji: "🙁"},
    {name: "Lonely", positive: false, emoji: "😢"},
    {name: "Upset", positive: false, emoji: "😭"},
    {name: "Melancholy", positive: false, emoji: "😔"},
    {name: "Annoyed", positive: false, emoji: "😒"},
    {name: "Tired", positive: false, emoji: "🥱"},
    {name: "Stressed", positive: false, emoji: "😖"},
] 
    %>
    <div id="wrapper">
        <% if (typeof splash == 'string'){  %>
            <p class="splash"><%- splash %></p>
        <% } %>
        <section>
            <h2><%= Buffer.from(session.chosenAlter.name, 'base64').toString() %>'s page</h2>
            <dt>
            <% if (session.chosenAlter.mood) { %>
                Feeling: <%- moods[session.chosenAlter.mood].name %> <%- moods[session.chosenAlter.mood].emoji %>
            <% } %>
            </dt>
        <dd><small><% if (session.chosenAlter.mood) { %>
            Reason: <%- session.chosenAlter.reason %>
        <% } %><a href="/mood/<%=session.chosenAlter.alt_id %>">Set mood</a><% if (session.chosenAlter.mood) { %>
            | <a href="/del-mood/<%=session.chosenAlter.alt_id %>">Clear mood</a>
        <% } %></small></dd>
            <form method="post" autocomplete="off">
              <input type="text" name="altname" value="<%= Buffer.from(session.chosenAlter.name, 'base64').toString() %>" style="text-align:center;"> is a part of <select name="alterSys" style="text-align:center;"><% for (i in session.sysList){ %>
                <% if (session.chosenAlter.sys_alias == session.sysList[i].sys_alias){ %>
                  <option value="<%= session.sysList[i].sys_id %>" selected><%= Buffer.from(session.sysList[i].sys_alias, 'base64').toString() %></option>
                <% } else { %>
                  <option value="<%= session.sysList[i].sys_id %>"><%= Buffer.from(session.sysList[i].sys_alias, 'base64').toString() %></option>
                <% } %>
                <% } %>
              </select>
              <input type="submit" name="modify" value="Update">
            </form>
            <% if (session.altJournal.length > 0){ %>
                <!-- <p><%= session.altJournal[0].is_private %></p> -->
				<p>Click on the journal to enter.</p>
                <div id="blogpopup" style="display:none;">
                    <form method="post" autocomplete="off">
                        <p>Please put in the journal password.</p>
                        <input type="password" name="logPass" autocomplete="off">
                        <input type="submit" name="log" value="Open Journal">
                    </form>
                    <button id="forgotpass" style="cursor:pointer">I forgot...</button>
                    <form id="rj" name="resetjournal" style="display:none;" method="post">
                        <p>No problem. Because journal passwords are treated like the one on your account, we can't show you what the original password was. You'll need to put a new one in.</p>
                        <label for="passnew">New Journal password</label>
                        <input type="password" id="passnew" name="jPassNew" autocomplete="new-password"><br><span id="passtextNew"></span><br>
                        <input type="submit" value="Change <%= Buffer.from(session.chosenAlter.name, 'base64').toString() %>'s Password" name="changePass">
                    </form>
                </div>
                <% if (session.altJournal[0].is_private == true){ %>
                    <img class= "pixelart" src="/img/<%- (session.altJournal[0].skin).replace(/'/gi, '') %>.png" width="400px" id="login" onclick="blogPopup()" alt="<%= Buffer.from(session.chosenAlter.name, 'base64').toString() %>'s Journal.">
                <% } else { %>
                    <a href="/journal/<%- (session.altJournal[0].alt_id) %>"><img class="pixelart" src="/img/<%- (session.altJournal[0].skin).replace(/'/gi, '') %>.png" width="400px" id="login" alt="<%= Buffer.from(session.chosenAlter.name, 'base64').toString() %>'s Journal."></a>
                <% } %>
                <section>
            <form method="post" name="changejournal">
                <label for="skin">Change Journal skin:</label>
                <select name="skin" id="skin">
                 <% for (i in journalArr) { %>
                    <% if (parseInt(session.altJournal[0].skin) == parseInt(journalArr[i].val)){ %>
                        <option value="<%- journalArr[i].val %>"><%- journalArr[i].c %></option>
                    <% } else { %>
                        <option value="<%- journalArr[i].val %>"><%- journalArr[i].c %></option>
                    <% } %>
                    <% } %>
                    
                </select> 
                <input type="submit" name="newjournalSkin" value="Update Journal Skin">
                </form>
        </section>
            <% } else { %>
                <h2>Uh oh!</h2> <p><%= Buffer.from(session.chosenAlter.name, 'base64').toString() %> has no journal. Make one down below.</p>
                <form method="post" autocomplete="off">
                    <div class="parent" style="height: auto;margin:auto;">
                    <% for (let i=0; i < 13; i++){ %>
                        <div class="radio-toolbar child">
                            <input type="radio" id="<%= i+1 %>" name="journ" value="<%= i+1 %>">
                            <label for="<%= i+1 %>"><img src="/img/<%= i+1 %>.png" class="tinyimg"  style="display:block; margin:0 auto;"><%= ['Red', 'Orange', 'Yellow', 'Green', 'Teal', 'Blue', 'Purple', 'Pink', 'White', 'Black', 'Rainbow', 'Ocean', 'Space'][i] %></label>
                        </div>
                    <% } %>
                    </div>
                    <p>Password Protect this journal?</p>
                        <input type="radio" id= "true" name="priv" value="true">
                        <label for="priv">Yes</label><br/>

                        <input type="radio" id= "false" name="priv" value="false" checked>
                        <label for="priv">No</label>
                    <div id="more" style="display: none;">
                        <label for="pass">Journal password</label>
                        <input type="password" id="pass" name="jPass" autocomplete="off"> <span id="passtext"></span>
                    </div>
                    <br/>
                    <!-- <hr/> -->
                    <input type="submit" value="Create <%= Buffer.from(session.chosenAlter.name, 'base64').toString() %>'s Journal" name="create">
                    <p id="passhint" style="display: none;"><strong>Keep your password somewhere safe.</strong></p>
                </form>
            <% } %>
        </section>
        <hr>
        <section>
            <!-- For adding alter info. -->
            <h2>About <%= Buffer.from(session.chosenAlter.name, 'base64').toString() %></h2>
            <% if (session.chosenAlter.img_url) { %>
            <img src="<%= Buffer.from(session.chosenAlter.img_url, 'base64').toString() %>" class="medimg" style="float:left; margin-right:calc(1em);">
            <% } else { %> 
                <img src="https://i.ibb.co/vkwmWjF/avatar-default.jpg" class="medimg" style="float:left; margin-right:calc(1em);" alt="<%= Buffer.from(session.chosenAlter.name, 'base64').toString() %>'s icon">
            <% } %>
            <table>
                <tbody>
                  <tr>
                    <% if (session.chosenAlter.age && session.chosenAlter.age > 0) { %>
                            <td>Perceived Age:</td>
                            <td><%= session.chosenAlter.age %></td>
                        <% } %>
                  </tr>
                  <tr>
                    
                    <% if (session.chosenAlter.type) { %>
                        <td>Type:</td>
                        <td><%= alterTypes[session.chosenAlter.type] %></td>
                    <% } %>
                  </tr>
                  <tr>
                    
                    <% if (session.chosenAlter.triggers_pos) { %>
                        <td>Positive Triggers:</td>
                        <td><%= Buffer.from(session.chosenAlter.triggers_pos, 'base64').toString() %></td>
                    <% } %>
                  </tr>
                  <tr>
                    <% if (session.chosenAlter.triggers_neg) { %>
                        <td>Negative Triggers:</td>
                        <td><%= Buffer.from(session.chosenAlter.triggers_neg, 'base64').toString() %></td>
                    <% } %>
                  </tr>
                  <tr>
                    <% if (session.chosenAlter.likes) { %>
                        <td>Likes:</td>
                        <td><%= Buffer.from(session.chosenAlter.likes, 'base64').toString() %></td>
                    <% } %>
                  </tr>
                  <tr>
                    <% if (session.chosenAlter.dislikes) { %>
                        <td>Dislikes:</td>
                        <td><%= Buffer.from(session.chosenAlter.dislikes, 'base64').toString() %></td>
                    <% } %>
                  </tr>
                  <tr>
                    
                    <% if (session.chosenAlter.job) { %>
                        <td>Internal Job:</td>
                        <td><%= Buffer.from(session.chosenAlter.job, 'base64').toString() %></td>
                    <% } %>
                  </tr>
                  <tr>
                    
                    <% if (session.chosenAlter.safe_place) { %>
                        <td>Feels safest when:</td>
                        <td><%= Buffer.from(session.chosenAlter.safe_place, 'base64').toString() %></td>
                    <% } %>
                  </tr>
                  <tr>
                    
                    <% if (session.chosenAlter.wants) { %>
                        <td>Wants/Wishes:</td>
                        <td><%= Buffer.from(session.chosenAlter.wants, 'base64').toString() %></td>
                    <% } %>
                  </tr>
                  <tr>
                    <% if (session.chosenAlter.acc) { %>
                        <td>Needs accommodated for:</td>
                        <td><%= Buffer.from(session.chosenAlter.acc, 'base64').toString() %></td>
                    <% } %>
                  </tr>
                  <tr>                    
                    <% if (session.chosenAlter.notes) { %>
                        <td>Other Notes:</td>
                        <td><%= Buffer.from(session.chosenAlter.notes, 'base64').toString() %></td>
                    <% } %></td>
                  </tr>
                </tbody>
                </table>
                <a title="Edit <%= Buffer.from(session.chosenAlter.name, 'base64').toString() %>" href="/edit-alter/<%= session.chosenAlter.alt_id %>" class="editbtn">Edit <%= Buffer.from(session.chosenAlter.name, 'base64').toString() %></a>
        </section>
        <hr>
        <section>
            <h2><span class="material-symbols-outlined">dangerous</span> Danger Zone <span class="material-symbols-outlined">dangerous</span></h2>
            <form method="post">

            </form>
            <!-- Delete the alter. -->
            <a style="margin-top: calc(1em)" href="/alter/<%= session.chosenAlter.alt_id %>/delete" class="deletebtn">Delete <%= Buffer.from(session.chosenAlter.name, 'base64').toString() %></a>
        </section>
    </div>

    <%- include ("../partials/footer.ejs") %>
    <script>


        $("#pass").on('keyup', function () {
            document.getElementById("passtext").style.color="gray";
            $("#passtext").html(`<small>You typed: ${$("#pass").val()}</small>`);
            });

        $("#forgotpass").click(function(){
            // Toggle password tooltip and the reset.
            $( "#rj" ).show("fast");
            $("#forgotpass").hide("fast");
        });

        $("#passnew").on('keyup', function () {
            document.getElementById("passtextNew").style.color="gray";
            $("#passtextNew").html(`<small>You typed: ${$("#passnew").val()}</small>`);
            });

        document.getElementById("true").addEventListener("click", function(){
            $( "#more" ).show("fast");
            $( "#passhint" ).show("fast");
        });
        document.getElementById("false").addEventListener("click", function(){
            $( "#more" ).hide("fast");
            $( "#passhint" ).hide("fast");
        });
        function showPass(){
            document.getElementById("passtext").style.color="gray";
            return document.getElementById("passtext").innerHTML=`Your password is: ${document.getElementById('pass').value}`;
        }
        function blogPopup(){
            document.getElementById("blogpopup").style.display="block";
        }
        $("#moodButton").click(function(){
            $( "#moodForm" ).show("fast");
        });

    </script>
</body>

</html>
