<!DOCTYPE html>
<html lang="en" dir="ltr" style="visibility: hidden;">

<head>
    <%- include ("../partials/header.ejs") %>
</head>

<body>
    <%- include ("../partials/nav.ejs") %>
    <div id="wrapper">
        <% if (locals.messages.flash) { %>
            <div class="splash"><%- locals.messages.flash %></div>
        <% } %>
        <section>
            <h2>Delete <%= Buffer.from(session.chosenAlter.name, 'base64').toString() %>?</h2>
            <h3 class="warningtext">Warning: This cannot be undone!</h3>
            <p><%= Buffer.from(session.chosenAlter.name, 'base64').toString() %>'s journal and posts will be permanently deleted. Are you absolutely sure this is what you want to do? Press the "delete" button if so.</p>
            <form method="post">
                <input class="warningbutton" type="submit" value="Delete <%= Buffer.from(session.chosenAlter.name, 'base64').toString() %> forever" name="delete">
            </form>
        </section>
    </div>
    <%- include ("../partials/footer.ejs") %>
</body>

</html>
