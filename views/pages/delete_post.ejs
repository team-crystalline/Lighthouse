<!DOCTYPE html>
<html lang="en" dir="ltr" style="visibility: hidden;">

<head>
    <%- include ("../partials/header.ejs") %>
</head>

<body>
    <%- include ("../partials/nav.ejs") %>
    <div id="wrapper">
        <% if (locals.messages.flash) { %>
            <div class="splash"><%- locals.messages.flash %></div>
        <% } %>
        <section>
            <h2>Delete <%- session.jPost.title %>?</h2>
            <h3 class="warningtext">Warning: This cannot be undone!</h3>
            <p>This post cannot be recovered. Are you absolutely sure this is what you want to do? Press the "delete" button if so.</p>
            <form method="post">
                <input class="warningbutton" type="submit" value="Delete" name="delete">
            </form>
            <hr/>
            <h3>Your post:</h3>
            <pre>
                <%- session.jPost.body %>
            </pre>
        </section>
    </div>
    <%- include ("../partials/footer.ejs") %>
</body>

</html>
