<!DOCTYPE html>
<html lang="en" dir="ltr">

<head>
    <%- include ("../partials/header.ejs") %>
</head>

<body>
    <%- include ("../partials/nav.ejs") %>
    <div id="wrapper">
        <section>
            <% if (typeof splash == 'string'){  %>
                <p class="splash"><%- splash %></p>
            <% } %>
            <h2>Delete?</h2>
            <h3 class="warningtext">Warning: This cannot be undone!</h3>
            <p>Any alters under this system will be deleted as well, as well as their journals. Are you absolutely sure this is what you want to do? Press the big red button if so.</p>
            <form method="post">
                <input class="warningbutton" type="submit" value="Delete" name="delete">
            </form>
        </section>
    </div>
    <%- include ("../partials/footer.ejs") %>
</body>

</html>
