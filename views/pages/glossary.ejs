<!DOCTYPE html>
<html lang="en" dir="ltr" style="visibility: hidden;">
    <head>
        <%- include ("../partials/header.ejs") %>
        <title>Lighthouse- Glossary</title>
        <style>
            dt{
                font-style: normal;
                cursor: pointer;
            }
            #important{
                display: block;
            }
            #important > div {
            display: block;
            }
            #copyNotification{
                z-index: 5;
                position: fixed;
                bottom: 0;
                right: 0;
                width: 30%;
                padding: 1em;
                background: var(--col2);
                display: none;
            }
        </style>
    </head>
    <%- include ("../partials/nav.ejs") %>
    <body>
        <div id="copyNotification">Copied Link!</div>
        <div id="wrapper">
            
            <% if (locals.messages.flash) { %>
                <div class="splash"><%- locals.messages.flash %></div>
            <% } %>
            <h2>Glossary</h2>
            <p>The terms used in plural spaces are not usually ones known to the layman. Here are a list of terms you might see being used.</p>
            <p><strong>This page isn't fully complete.</strong> Terms are still being added. Terms that are deemed important are in different colour text. Click on a term to copy a link to this term. Feel free to share this page!</p>
            <section>
            <h3>Important Terms</h3>
            <p>It's best to understand these terms first before reading further.</p>
            <dl id="important">
                <% for (i in important) { %> 
                    <div id="<%- important[i].linkalias %>" style="scroll-margin-top: 10em;">
                    <dt onclick="copyLink('<%- important[i].linkalias %>')" class="importantterm"><%- important[i].term %> <small><em>(<%- important[i].type %>)</em></small></dt>
                    <dd><%- important[i].definition %></dd>  
                    </div>
                <% } %>
            </dl>
        </section>
        <hr>
        <section>
            <h3>All Terms</h3>
            <% var abc = "ABCDEFGHIJKLMNOPQRSTUVWXYZ".split(""); 
               var termsLetters= new Array();
               for (t in terms) { 
                termsLetters.push(terms[t].start_letter);
               } 
               %>
            <div style="display:flex; justify-content: space-around;">
                <% for (i in abc){ 
                    var count = termsLetters.filter(x => x == abc[i]).length;
                    if (count > 0) {
                    %>
                    <a href="/glossary#<%-abc[i] %>"><%- abc[i]%></a>
                    <% } %>
                <% } %>
            </div>
            
            <% for (n in abc) { 
                var count = termsLetters.filter(x => x == abc[n]).length;
                    if (count > 0) {
                %>
                <h3 class="lettc" id="<%- abc[n] %>"><%- abc[n] %></h3>
                <div class="collapsible">
                    <% for (i in terms) { 
                        
                        if (terms[i].start_letter == abc[n]){ %>
                            <div id="<%- terms[i].linkalias %>" style="scroll-margin-top: 10em;">
                    <% if (terms[i].essential== true) { %> 
                        <dt class="importantterm" onclick="copyLink('<%- terms[i].linkalias %>')"><%- terms[i].term %> <small><em>(<%- terms[i].type %>)</em></small></dt>
                    <% } else { %>
                        <dt onclick="copyLink('<%- terms[i].linkalias %>')"><%- terms[i].term %> <small><em>(<%- terms[i].type %>)</em></small></dt>
                    <% } %>
                    <dd><%- terms[i].definition %></dd>  
                    </div>
                        <% } %>
                    <% } %>
                </div>
                <!-- End ABC Loop -->
             <% } %>
           <% } %>
        </section>
    </div>
    <%- include ("../partials/footer.ejs") %>
    <script>
        // console.log(window.location.hash)
        if (window.location.hash){
            // console.log("Found hash")
            $(`${window.location.hash}`).css("background-color", "rgba(255, 255, 0, .2)")
        }
        function copyLink(url) {
            navigator.clipboard.writeText(`www.writelighthouse.com/glossary/#${url}`);
            $("#copyNotification").show().delay(3000).fadeOut("slow");
            } 
        </script>
    </body>
</html>
