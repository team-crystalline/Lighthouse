<!DOCTYPE html>
<html lang="en" dir="ltr">
    <head>
        <%- include ("../partials/header.ejs") %>
        <style>
            #features > div{
                margin-bottom: 3em;
            }
            #features>div:nth-child(odd) {
                text-align: left;
            }

            #features>div:nth-child(even) {
                text-align: right;
            }
            #desktopsection{
                    display: block;
                    /* float: right; */
                }
            form{

                width: 25vw;
                padding: 1em; 
                height: 27vh;
                margin-left: 3em;
                margin-bottom:2em; 
                /* border-bottom: 1px solid var(--col1); */
            }
            input{
                margin-bottom:1em;
                display: block;
            }
            #signup{
                color: var(--col4);
                font-weight: 800;
                cursor: pointer;
                text-decoration: underline;
            }
            @media only screen and (max-width: 600px) {
                form{
                    width: 85vw;
                    padding: .5em; 
                    /* height: 25vh;  */
                    border-left: 0;
                    margin-left: auto;
                    margin-bottom: 3em;
                }
            }

        </style>
    </head>
    <body>
        <script>0</script>
        <%- include ("../partials/nav.ejs") %>
        <div id="wrapper">
            <div style="text-align:center;">
                <% if ((new Date().getMonth()+1)==6) { %>
                    <p class="alert alert-info"><img src="/img/svg/ptsd-support.svg" class="vtinyimg" alt="An anchor with an awareness ribbon around it." style="margin-right: 1em;"> June is PTSD awareness month.</p>
                    <% } %>
                    <% if ((new Date().getMonth()+1)==7) { %>
                        <p class="alert alert-info"><img src="/img/svg/cane.svg" class="vtinyimg" alt="A person with a cane." style="margin-right: 1em;"> July is Disability Pride Month! <img src="/img/svg/wheelchair.svg" class="vtinyimg" alt="A person in a wheelchair."></p>
                        <% } %>
                    <% if (((new Date().getMonth()+1)== 3) && (new Date().getDate()) == 5) { %>
                        <img src="/img/svg/ptsd-support.svg" class="vtinyimg" alt="An anchor with an awareness ribbon around it." style="margin-right: 1em;">  Today is DID Awareness Day.
                        <% } %>
                    <% if (((new Date().getMonth()+1)== 7) && (new Date().getDate()) == 15) { %>
                        <p class="alert alert-info">👥 Today is Plural Pride Day!</p>
                   <% } %>

                   <% if (((new Date().getMonth()+1)== 12) && (new Date().getDate()) == 15) { %>
                    <p class="alert alert-info">🎂 Today is Lighthouse's <%= new Date().getFullYear() - 2021 %><%= getOrdinal(new Date().getFullYear() - 2021) %> Anniversary! Thank you for supporting us this long!</p>
               <% } %>
               
             </div>  

                        <div id="loggedIn" class="splash" style="display:none">Hi, <span id="greeting">friend</span>! You are now logged in. Redirecting you now...</div>
                <div id="wrongpass" class="splash" style="display:none">Incorrect email and/or password. <a href="/forgot-password">Need to reset your password?</a></div>
            
            
            <!-- <h1 style="font-family: 'Berkshire Swash','Lobster Two', cursive;font-size:3em;margin-bottom:-.5em">Lighthouse</h1> -->
            <% if (messages.flash){ %> <p class="splash"><%- messages.flash %></p><% } %>
            <%  if (!cookies.loggedin){ %>
                <!-- Login -->
                <form method="post" style="float: left; height: auto;">
                    <h2>Log In</h2>
                    <small>No Account? <a id="signup" href="/signup">Signing Up takes only a minute!</a></small><br/>
                    <label for="email">Email: </label>
                    <input type="email" placeholder="something@mail.com" name="email" id="email"></br>
                    <label for="password">Password: </label>
                    <input type="password" name="password" id="password"><br/>
                    <button id="login">Log In</button>
                    <div id="Wait" style="display:none"><img src="/img/svg/bubbles.svg" class="tinyimg"></div>
                </form>
                <% } %>   
                <% 
                var altTerm;
                var sysTerm;
                if (cookies.alter_term){
                    altTerm= cookies.alter_term;
                } else {
                    altTerm= "alter";
                }
                if (cookies.system_term){
                    sysTerm= cookies.system_term;
                } else {
                    sysTerm= "system";
                }
                if (cookies.subsystem_term){
                    subsysTerm= cookies.subsystem_term;
                } else {
                    subsysTerm= "subsystem";
                }
                %>
                
            <hgroup style="text-align:center;">
                <h2>Journal Together</h2></hgroup>
                
                <section id="desktopsection">                 
                </section>
                
                <section style="text-align:center;">
                    <img src="/img/<%= Math.floor(Math.random() * (18 - 1 + 1)) + 1  %>.png" alt="a journal book" style="display:inline; height: 256px; width: auto;margin-bottom:-1em;" class="pixelart">
                </center>
                <h4>We're helping  <span style="color:var(--col1)"><%= (parseInt(userCount)).toLocaleString() %></span> <%= pluralize(sysTerm) %>!</h4>
               
            </section>
            <article style="float:none;border:0;">
                <p>We use cookies to keep your experience running smoothly while logged in. <a href="/cookies">Read more here.</a></p>
            <p>Lighthouse is a safe and supportive space for people with PTSD and DID to explore their thoughts and feelings, identify their different <%- pluralize(altTerm) %>, and develop healthy and positive communication internally.<%  if (!cookies.loggedin){ %> <a href="/signup">Sign up today and start your journey.</a><% } %></p>
                <p><small>
                    <i class="fa fa-anchor" aria-hidden="true"></i>
                    Lighthouse was not developed by a medical professional, and is not intended to be a substitute for professional advice, diagnosis, or treatment. Always seek the advice of your mental health professional or other qualified health provider with any questions you may have regarding your condition.</small></p>
                    <p><a href="/about#credits">Image Credits Here.</a></p>
                    <center>
                        <p>Designed and programmed by The Lighthouse System.</p>
                        <script type='text/javascript' src='https://storage.ko-fi.com/cdn/widget/Widget_2.js'></script><script type='text/javascript'>kofiwidget2.init('Support Us on Ko-fi!', '#29abe0', 'M4M81XKEG');kofiwidget2.draw();</script></center> 
            </article>
            
        <hr>
        <section id="features">
            <div>
                <div><h2>Create a Space for Your <%- capitalise(pluralize(altTerm)) %></h2>
                    <p><%- capitalise(pluralize(altTerm)) %> get a private journal for their own thoughts and feelings that can be safe-guarded with a password.</p></div>
                
            </div>
            <div>
                <div><h2>Keep Your <%- capitalise(sysTerm) %> Informed</h2>
                    <p>Users get both a Communal Journal and an Internal Forum that can be used by all <%- pluralize(altTerm) %> to keep everyone up-to-date.</p></div>
                
            </div>
            <div>
                <div><h2>Get to the Root of Feelings</h2>
                    <p>Each <%- altTerm %> can set a mood with a short reason as to why they feel that way.</p></div>
                
            </div>
            <div>
                <div><h2>Understand Your <%- capitalise(pluralize(altTerm)) %> Better</h2>
                    <p><%- capitalise(pluralize(altTerm)) %> can provide basic information on themselves, but can also address what makes them feel safe, what they would want from the <%- sysTerm %>, and what they would like accommodations for.</p>
                    <p>Users can also <strong>create nested <%= pluralize(subsysTerm) %>, or a second standalone <%= sysTerm %></strong>, for those with complex <%= pluralize(sysTerm) %>.</p>
                </div>
                
            </div>
            <div>
                <div><h2>Import from Pluralkit & Simply Plural</h2>
                    <p>If you already use the popular Discord bot <strong>Pluralkit</strong> or the app <strong>Simply Plural</strong>, you can import your <%- sysTerm %> into Lighthouse!</p></div>
                
            </div>
            <div>
                <div><h2>Interactive Worksheets</h2>
                    <p>If you have a trauma-based <%= sysTerm %> or would like to use trauma worksheets, Lighthouse has a growing number of interactive pages to help process emotions, make a safety plan, or prepare for an event that you know will be stressful or triggering.</p><p><small>*These worksheets are intended for educational and informational purposes only and should not be used as a substitute for professional mental health care.</small></p></div>
                
            </div>
        </section>
        <% if (donators.length > 0){ %>
            <hr>
            <section>
            <h2>Thank You to Our Supporters</h2>
            <div style="display:grid;grid-template-columns: 1fr 1fr 1fr 1fr;line-height: 2;">
                <% for (i in donators) { %> 
                    <div style="padding:1em;line-height:1;text-align:center;"><%- donators[i].nickname %></div>
                    <%} %>
            </div>
        </section>
        <% } %>
        
    </div>
    <%- include ("../partials/footer.ejs") %>
    <script>
        $("#login").click(async function(){
            event.preventDefault();
            $("#login").hide();
            $("#Wait").show();
        let response = await fetch(`/api/user/auth`, { 
            method: "GET",
            headers: { 
              "api-lh-call": "api-lh-call",
              'Content-Type': 'application/json',
              'email': $("#email").val(),
              'tok': $("#password").val(),
            }
        });
        let resBod = await response.text();
        if (response.ok){
            // Good. Proceed to log in.
            let userInfo = JSON.parse(resBod);
            $("#wrongpass").hide();
            $.iaoAlert({ msg: `Hello, ${userInfo.name}! You are now logged in.`, type: "success", mode: "dark", autoHide: false })
            setTimeout(async function(){
                window.location.replace("/system");
            }, 3000);
        } else {
            $("#Wait").hide();
            $("#login").show();
            $.iaoAlert({ msg: `Wrong Email or Password. <a href="/forgot-password">Need to reset your password?</a>`, type: "error", mode: "dark", autoHide: false})
        }
        })
    </script>
    </body>
</html>
