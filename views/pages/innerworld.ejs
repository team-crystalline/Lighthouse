<!DOCTYPE html>
<html lang="en" dir="ltr">
    <head>
        <%- include ("../partials/header.ejs") %>
        <style>
          .textless{
            height: 1em;
            display: inline;
            font-size: 1.15em;
            padding: 0;
            vertical-align: text-top;
            background: transparent;
            color: var(--col5)
          }
        </style>
    </head>
    <body>
        <%- include ("../partials/nav.ejs") %>
        <div id="wrapper">
            <section>
              <% if (locals.messages.flash) { %>
                <div class="splash"><%- locals.messages.flash %></div>
            <% } %>
                <h2><%= capitalise(session.innerworld_term) %></h2>
                <% if (session.innerworld == false) { %> 
                <p><strong><%= capitalise(pluralize(session.innerworld_term)) %> are not enabled on this account.</strong> Not everyone has one. You can change this in <a href="/profile" title="Settings">Settings</a>.</p>
                <% } else { %>
                  <p>Your <strong><%= session.innerworld_term %></strong> is a visualisation tool for people to visualise <%= pluralize(cookies.alter_term) %>, memory storage, feelings, and more. <%= capitalise(pluralize(session.innerworld_term)) %> can be as small as a singular room, or as big as an entire planet. In the end, it's all about what makes you feel safest. Think of it as your happy place. Here, you can describe sections of your <%= session.innerworld_term %> for other <%= pluralize(cookies.alter_term) %> who may struggle to visualise it.</p>
                  <form method="post">
                    <label for="key">Name</label><br/>
                    <input type="text" name="key" required><br/>
                    <label for="value" id="DescLabel">Description (Be as descriptive as you'd like)</label><br/>
                    <div id="editor"></div>
                    <textarea id="hidden-text" name="value" style="display:none"></textarea>
                    <br/>
                    <input type="submit" name="create" value="Add">
                    <input type="reset" value="Start Over">
                  </form>
                  <% chosenPlace= randomise([{name: "The Beach", desc: "A sandy shore with blue waters and a calm breeze."}, {name: "Main Planet", desc: "The main planet most "+ pluralize(cookies.alter_term) +" inhabit. Has lots of water and trees."}, {name: "The Mansion", desc: "This mansion is 3 stories tall with a basement. Has 6 bedrooms and 5 bathrooms. Most of the main " + pluralize(cookies.alter_term) + " live here."}]); %>
                  <p>Example:</p>
                  <p>Name: <%= chosenPlace.name %></p>
                  <p>Description: <%= chosenPlace.desc %></p>
              </section>
              <section>
                <h2>About Your <%= capitalise(session.innerworld_term) %></h2>
                <% for (i in session.innerworld_rows){ %>
                  <dt><%= Buffer.from(session.innerworld_rows[i].key, 'base64').toString() %> <form method="post" style="display: inline;"><button type="submit" name="<%= session.innerworld_rows[i].id %>" value="Remove" class="textless" onclick="deleteWarn('<%= Buffer.from(session.innerworld_rows[i].key, 'base64').toString() %>')"><span class="material-symbols-outlined textless"> delete</span></button></form><a title="Edit entry" href="/inner-world/<%- session.innerworld_rows[i].id %>"><i class="fa fa-pencil" aria-hidden="true"></i></a></dt>
                  <dd class="md-support"><%- (Buffer.from(session.innerworld_rows[i].value, 'base64').toString()).replace(/\n/g, "<br/>") %></dd>
                <% } %>
  
                <%}%>
                
            </section>
        </div>
        <%- include ("../partials/quill.ejs") %>
        <%- include ("../partials/scripts.ejs") %>
        <%- include ("../partials/footer.ejs") %>

    </body>
    <script>
      const controller = new AbortController();
    const { signal } = controller;
    
        function deleteWarn(title){
          if (confirm(`You're about to delete ${title}.\nAre you sure?`)){
            console.log("Deleting.")
          } else {
            event.preventDefault();
          }
        }
    
        signal.addEventListener("abort", () => {
      console.log(signal.aborted);
    });
    $(document).ready(function () {
      fetchPosts().then(() => {
        const markdownSupp = $(".md-support");

        markdownSupp.each(function () {
          const b = $(this);
          b.children().each(function () {
            const a = $(this);
            const existingText = a.html();
            const parsedHtml = marked
              .parse(existingText, { sanitize: false })
              .replace("“", "")
              .replace("”", "");
            a.html(parsedHtml);
            // Wheeee callback hell :3
          });
        });
      });
    });
    </script>
</html>
