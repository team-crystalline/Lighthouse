<!DOCTYPE html>
<html lang="en" dir="ltr" style="visibility: hidden;">
    <head>
        <%- include ("../partials/header.ejs") %>
        <style>
          input[type=email],input[type=username],input[type=password],input[type=submit], #passSplash{
            display: block;
          }
          #passSplash{
            margin-top: -2em;
            margin-bottom: 1em;
            font-weight: 300;
            font-style: italic;
            font-size: .85em;
          }
        </style>
    </head>
    <body>
        <%- include ("../partials/nav.ejs") %>
        <div id="wrapper">
          <% if (locals.messages.flash) { %>
            <div class="splash"><%- locals.messages.flash %></div>
        <% } %>
            <h2>Sign Up to Lighthouse</h2>
            <p>We're happy to have you! But first, we need some  information. <strong>Please use a valid, non-temporary email.</strong> That way if you lose your password, you can still reset it. We only email you when you've made an account, when you delete an account, if you lose your password, or if there's a situation in which we need to email all of our users (like a Terms of Service update, or when we eventually implement 2FA).</p>
            <form method="post" autocomplete="off">
              <label for="email">Email: <br></label><input style="display:inline-block;" type="email" autocomplete="off" placeholder="Email" id="email" name="email" required><span  id="emailpf"></span>
                <br>
                <label for="username">Username: <br></label>
                <input style="display:inline-block;" type="username" autocomplete="off" id="username" placeholder="Username" name="username" min="3" required><span id="userpf"></span>
                <br>
                <label for="password">Password: </label>
                <input minlength="8" type="password" autocomplete="off" placeholder="Write your password." name="password" id="pass" required>
                <label for="v-password">Verify Password: </label>
                <input minlength="8" type="password" autocomplete="off" placeholder="Write it again." name="v-password" id="v-pass" required>
                <span id="passSplash"></span>
                <input type="checkbox" style="margin-top: 1em;" id="agreement" onchange="verifySubmit()"> <label for="agreement">By signing up, you agree to the <a href="/tos" target="_blank">Terms of Service</a> and <a href="/cookies" target="_blank">cookie usage</a>. See our <a href="/privacypolicy" target="_blank">Privacy Policy</a>.</label>
                <!-- Weird name to bypass any software that looks for keywords, like "spam", "verify" -->
                <input type="hidden" name="mjl2fbbz8s" id="mjl2fbbz8s" placeholder="Users should not see this! This is a bot honeypot.">
                <input type="submit" id="signup" value="Sign Up" disabled>
            </form>
        </div>
        <%- include ("../partials/footer.ejs") %>
        <script>
          /* -------------------------------- */
          const button= document.querySelector("#signup");
          const pass= document.querySelector("#pass");
          const vPass= document.querySelector("#v-pass");
          const passSplash= document.querySelector("#passSplash");
          var emailReg= /[a-z0-9._%+\-]+@[a-z0-9.\-]+\.[a-z]{2,}$/;
          /* -------------------------------- */

          function randomise (arr){
              return arr[Math.floor(Math.random()*arr.length)];
            }
          function verifySubmit(){
            if (pass.value.length >= 8 && (pass.value.match(/^(?=.*[a-zA-Z])(?=.*[0-9])/)) && document.querySelector('#agreement').checked && $("#email").val().match(emailReg) && $("#username").val().length >= 3 && $("#emailpf").text()== "✅"&& $("#userpf").text()== "✅"){
              button.disabled= false;
            } else {
              button.disabled=true;
            }
          }

          $("#pass, #v-pass").on("keyup", function(){
            if (pass.value !== vPass.value){
              passSplash.innerHTML="Passwords do not match.";
            } else {
              passSplash.innerHTML="";
            }
            if (pass.value.length < 8 || (!pass.value.match(/^(?=.*[a-zA-Z])(?=.*[0-9])/))){
              passSplash.innerHTML+= " Please make your password at least 8 characters with letters and a number."
            }
          });
          $("#email").bind("change paste keyup keydown", async function(){
            if (!$("#email").val().match(emailReg)) return;
            let response = await fetch(`/users`, {
				headers: {
				"api-lh-call": "api-lh-call",
				"email": $("#email").val()
				}
          });
            let body = await response.text();
            let bodyInfo = JSON.parse(body);
            if (bodyInfo.taken== false){
				// Not taken and received HTTP code 200. Do it!
				$("#emailpf").text(`✅`);
				$("#signUp").prop('disabled', false);
			} else {
				// Either taken or the database didn't like that.
				$("#emailpf").text(`❌ In use`);
				$("#signUp").prop('disabled', true);
			}
      verifySubmit();
          });


          $("#username").bind("change paste keyup keydown", async function(){
            if ($("#username").val().length < 2) return;
            let response = await fetch(`/users`, {
				headers: {
				"api-lh-call": "api-lh-call",
				"username": $("#username").val()
				}
          });
            let body = await response.text();
            let bodyInfo = JSON.parse(body);
            if (bodyInfo.taken== false){
				// Not taken and received HTTP code 200. Do it!
				$("#userpf").html(`✅`);
				$("#signUp").prop('disabled', false);
			} else {
				// Either taken or the database didn't like that.
				$("#userpf").html(`❌ In use`);
				$("#signUp").prop('disabled', true);
			}
      verifySubmit();
          });
        </script>
    </body>
</html>
