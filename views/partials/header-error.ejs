<title>Lighthouse- <%- code %></title>
<link rel="stylesheet" type="text/css" href="/stylesheets/main.css?v=1.6.3" />
<link rel="icon" type="image/x-icon" href="/img/logo.png">
<script src="https://ajax.googleapis.com/ajax/libs/jquery/2.1.3/jquery.min.js"></script>
<link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200" />
<script defer>
    let domReady = (cb) => {
      document.readyState === 'interactive' || document.readyState === 'complete'
        ? cb()
        : document.addEventListener('DOMContentLoaded', cb);
    };
    
    domReady(() => {
      <% if (typeof cookies.skin == undefined || cookies.skin =="" ){ %>
        $("head").append(`<link rel="stylesheet" href="/stylesheets/lighthouse.css?v=<%- version %>">`);
      <% } else { %>
        $("head").append(`<link rel="stylesheet" href="/stylesheets/<%- session.skin || cookies.skin || 'lighthouse' %>.css?v=1.6.3">`);
      <% } %>
      
      // Display body when DOM is loaded
      let isDark= window.matchMedia("(prefers-color-scheme: dark)");
      console.log(localStorage.getItem("lighthouse_mode"))
      if (localStorage.getItem("lighthouse_mode")){
        document.querySelector("html").setAttribute("data-theme", localStorage.getItem("lighthouse_mode"));
      } else {
        let modeChoice= isDark.matches == true ? "dark" : "light";
        console.log(modeChoice)
        document.querySelector("html").setAttribute("data-theme", modeChoice);
      }

      <% if (cookies.textsize) { %> 

        $( "body" ).each(function( index ) {

          $(this).css("font-size", `${parseInt($(this).css("font-size")) * <%= parseFloat(cookies.textsize) || 1 %>}px`)
        });
      <% } %>
      document.body.style.visibility = 'visible';
    });
    
    
    </script>

<!-- Meta data -->
<meta 
  name    = "color-scheme" 
  content = "light dark"
/>

<meta charset="UTF-8">
<meta name="description" content="Lighthouse is a compartmentalised journalling app for people who are plural (have Dissociative Identity Disorder/DID, Otherwise Specified Dissociative Disorder/OSDD, or other situations). Keep track of day-to-day life, alters' feelings, and start building internal communication.">
<meta name="author" content="Dee Deyes">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<meta name="twitter:title" content="Lighthouse">
<meta property="og:image" content="https://i.ibb.co/RjFhMP6/Lighthouse-t.png">
