<Script>
  // Set dark mode based on user preference or system setting
  const isDark = window.matchMedia("(prefers-color-scheme: dark)");
  const modeChoice = localStorage.getItem("lighthouse_mode") || (isDark.matches ? "dark" : "light");
  document.querySelector("html").setAttribute("data-theme", modeChoice);

  <% 
    if (!session.system_term){
      session.system_term = "system";
    }
    if (!session.alter_term){
      session.alter_term = "alter";
    }
  
  %>
  // Set language direction if applicable
  <% if (session.language == "ar") { %>
    document.documentElement.setAttribute('lang', 'AR');
    $("html").attr("dir", "rtl");
  <% } %>


</Script>
    
