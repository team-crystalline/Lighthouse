<script>
  $(document).ready(function(){
  if ($(".dyn")[0]){
        // Replace html
        $(".dyn").each(function(){
          $(this).html($(this).html()
          // Systems
          .replace(/\[\[SYSTEMCAP\]\]/g, "<%= capitalise(cookies.system_term || session.system_term || "system") %>")
          .replace(/\[\[SYSTEMS\]\]/g, "<%= pluralize(cookies.system_term || session.system_term || "system") %>")
          .replace(/\[\[SYSTEMSCAP\]\]/g, "<%= capitalise(pluralize(cookies.system_term || session.system_term || "system")) %>")
          .replace(/\[\[SYSTEM\]\]/g, "<%= cookies.system_term  || capitalise(session.system_term)|| "system" %>")
          // Subsystems
          .replace(/\[\[SUBSYSTEMCAP\]\]/g, "<%= capitalise(cookies.subsystem_term  || capitalise(session.subsystem_term)|| "subsystem") %>")
          .replace(/\[\[SUBSYSTEMS\]\]/g, "<%= pluralize(cookies.subsystem_term  || capitalise(session.subsystem_term)|| "subsystem") %>")
          .replace(/\[\[SUBSYSTEMSCAP\]\]/g, "<%= capitalise(pluralize(cookies.subsystem_term  || capitalise(session.subsystem_term)|| "subsystem")) %>")
          .replace(/\[\[SUBSYSTEM\]\]/g, "<%= cookies.subsystem_term || capitalise(session.subsystem_term) || "subsystem" %>")
          // Alters
          .replace(/\[\[ALTERCAP\]\]/g, "<%= capitalise(cookies.alter_term || session.alter_term || "alter") %>")
          .replace(/\[\[ALTERS\]\]/g, "<%= pluralize(cookies.alter_term || session.alter_term || "alter") %>")
          .replace(/\[\[ALTERSCAP\]\]/g, "<%= capitalise(pluralize(cookies.alter_term || session.alter_term || "alter")) %>")
          .replace(/\[\[ALTER\]\]/g, "<%= cookies.alter_term || session.alter_term || "alter" %>")
          // Other terms
          .replace(/\[\[PLURAL\]\]/g, "<%= cookies.plural_term || session.plural_term || "plural" %>")
          .replace(/\[\[PLURALCAP\]\]/g, "<%= capitalise(cookies.plural_term || session.plural_term || "plural") %>")
          .replace(/\[\[PLURALS\]\]/g, "<%= pluralize(cookies.plural_term || session.plural_term || "plural") %>")
          .replace(/\[\[PLURALSCAP\]\]/g, "<%= capitalise(pluralize(cookies.plural_term || session.plural_term || "plural")) %>")
        )
        $(this).prop('title', $(this).prop('title')
          // Systems
          .replace(/\[\[SYSTEMCAP\]\]/g, "<%= capitalise(cookies.system_term || session.system_term || "system") %>")
          .replace(/\[\[SYSTEMS\]\]/g, "<%= pluralize(cookies.system_term || session.system_term || "system") %>")
          .replace(/\[\[SYSTEMSCAP\]\]/g, "<%= capitalise(pluralize(cookies.system_term || session.system_term || "system")) %>")
          .replace(/\[\[SYSTEM\]\]/g, "<%= cookies.system_term  || capitalise(session.system_term)|| "system" %>")
          // Subsystems
          .replace(/\[\[SUBSYSTEMCAP\]\]/g, "<%= capitalise(cookies.subsystem_term  || capitalise(session.subsystem_term)|| "subsystem") %>")
          .replace(/\[\[SUBSYSTEMS\]\]/g, "<%= pluralize(cookies.subsystem_term  || capitalise(session.subsystem_term)|| "subsystem") %>")
          .replace(/\[\[SUBSYSTEMSCAP\]\]/g, "<%= capitalise(pluralize(cookies.subsystem_term  || capitalise(session.subsystem_term)|| "subsystem")) %>")
          .replace(/\[\[SUBSYSTEM\]\]/g, "<%= cookies.subsystem_term || capitalise(session.subsystem_term) || "subsystem" %>")
          // Alters
          .replace(/\[\[ALTERCAP\]\]/g, "<%= capitalise(cookies.alter_term || session.alter_term || "alter") %>")
          .replace(/\[\[ALTERS\]\]/g, "<%= pluralize(cookies.alter_term || session.alter_term || "alter") %>")
          .replace(/\[\[ALTERSCAP\]\]/g, "<%= capitalise(pluralize(cookies.alter_term || session.alter_term || "alter")) %>")
          .replace(/\[\[ALTER\]\]/g, "<%= cookies.alter_term || session.alter_term || "alter" %>")
          // Other terms
          .replace(/\[\[PLURAL\]\]/g, "<%= cookies.plural_term || session.plural_term || "plural" %>")
        )
        })
      }
  })
</script>

