<!-- Meta data -->
<meta charset="UTF-8">
<meta name="description" content="Lighthouse is a self-help website for people who are plural (have Dissociative Identity Disorder/DID, Otherwise Specified Dissociative Disorder/OSDD, or other situations). Keep track of day-to-day life, alters' feelings, and start building internal communication.">
<meta name="keywords" content="DID, Dissociative Identity Disorder, OSDD, diary, journal, otherwise specified dissociative disorder, ddnos, multiplicity, plural, plurality, dissociative disorder not otherwise specified, journal app, diary app">
<meta name="author" content="The Lighthouse System">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<meta name="twitter:title" content="Lighthouse">
<meta property="og:image" content="/img/logo.png">
<meta property="og:description" content="Lighthouse is a self-help website for people who are plural (have Dissociative Identity Disorder/DID, Otherwise Specified Dissociative Disorder/OSDD, or other situations). Keep track of day-to-day life, alters' feelings, and start building internal communication.">
<meta property="og:title" content="Lighthouse">

<script>
    if (localStorage.lighthouse_mode){
        if (localStorage.lighthouse_mode== "dark"){
            $('head').append('<link type="text/css" rel="stylesheet" media="all" href="/stylesheets/dark.css">');
        }
    } else {
        localStorage.lighthouse_mode = "light";
    }


</script>