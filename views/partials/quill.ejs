<script>
  

let Font = Quill.import('formats/font');
    Font.whitelist = ['times-new-roman', 'arial', 'monospace', 'cursive', 'marker', 'creepster','homemade-apple', 'shadows' ,'redacted', 'rubik', 'notojp', 'notokr'];
    Quill.register(Font, true);
    
    var myToolbar= [
    // [{ size: [ 'small', false, 'large', 'huge' ]}],
    ['bold', 'italic', 'underline', 'strike'],       
    ['blockquote', 'code-block'],
    [{ 'list': 'ordered' },{ 'list': 'bullet'}, { 'indent': '-1' }, { 'indent': '+1' } ], 
    [{ 'color': [] }],         
    [{ 'font': ['', 'times-new-roman', 'arial', 'monospace', 'cursive','marker', 'creepster', 'shadows', 'homemade-apple', 'redacted', 'rubik', 'notojp', 'notokr'] }],
    [{ 'align': [] }],
    [{ 'direction': 'rtl' }],
    ['link', 'image'],
    ['clean']                                       
    
];


    var quill = new Quill('#editor', {
      modules: {
        toolbar: {
            container: myToolbar,
            handlers: {
                image: imageHandler
            }
        }
      },
      formats : [
            "background",
            "bold", 
            "color", 
            "font", 
            "code", 
            "italic", 
            "link", 
            "size", 
            "strike", 
            "script",
            "underline", 
            "blockquote", 
            "header",
            "indent", 
            "list", // <== Needed this in the list.
            "align", 
            "direction", 
            "code-block", 
            "formula", 
            "image",
            "video"
        ],
      theme: 'snow'  // or 'bubble'
    });
    function imageHandler() {
    var range = this.quill.getSelection();
    var value = prompt('please copy paste the image url here.');
    if(value){
        this.quill.insertEmbed(range.index, 'image', value, Quill.sources.USER);
    }
}
quill.formatLine(4, 'list', 'ordered');

// quill.format("list", "ordered");
$("#editor").on("paste change keyup keydown input", function(){
$("#hidden-text").text($(".ql-editor").html())
});
$('input[type=submit]').click(function(){
    // JUST in case.
    $("#hidden-text").text($(".ql-editor").html())
})


</script>